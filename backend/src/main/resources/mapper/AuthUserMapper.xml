<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiber.backend.auth.AuthUserMapper">
    <resultMap id="AuthUserRecordMap" type="com.jiber.backend.auth.AuthUserRecord">
        <constructor>
            <idArg column="user_id" javaType="java.lang.Long"/>
            <arg column="email" javaType="java.lang.String"/>
            <arg column="password_hash" javaType="java.lang.String"/>
            <arg column="display_name" javaType="java.lang.String"/>
            <arg column="role" javaType="java.lang.String"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="last_login_at" javaType="java.time.OffsetDateTime"/>
            <arg column="created_at" javaType="java.time.OffsetDateTime"/>
            <arg column="updated_at" javaType="java.time.OffsetDateTime"/>
        </constructor>
    </resultMap>

    <select id="findById" resultMap="AuthUserRecordMap">
        SELECT
            user_id,
            email,
            password_hash,
            display_name,
            role,
            enabled,
            last_login_at,
            created_at,
            updated_at
        FROM users
        WHERE user_id = #{userId}
    </select>

    <select id="findByEmail" resultMap="AuthUserRecordMap">
        SELECT
            user_id,
            email,
            password_hash,
            display_name,
            role,
            enabled,
            last_login_at,
            created_at,
            updated_at
        FROM users
        WHERE email = #{email}
    </select>

    <insert id="insertEmailUser">
        INSERT INTO users (
            email,
            password_hash,
            display_name,
            role,
            enabled,
            last_login_at
        ) VALUES (
            #{email},
            #{passwordHash},
            #{displayName},
            #{role},
            #{enabled},
            #{lastLoginAt}
        )
    </insert>

    <update id="updateLastLoginAt">
        UPDATE users
        SET last_login_at = #{lastLoginAt},
            updated_at = CURRENT_TIMESTAMP(6)
        WHERE user_id = #{userId}
    </update>
</mapper>
